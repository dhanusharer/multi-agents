# Kisan Saathi — Environment Variables
# Copy this file to .env and fill in your keys.

# Google Gemini API Key (required)
GOOGLE_API_KEY=your_google_api_key_here

# data.gov.in API Key (for scheme & MSP data)
DATA_GOV_IN_API_KEY=your_data_gov_in_api_key_here

# Open-Meteo / IMD Weather API (optional, free tier)
WEATHER_API_KEY=

# Agmarknet / eNAM Mandi API (optional)
MARKET_API_KEY=
